<view class="page">
  <view class="card section-card">
    <view class="section-name">杭麻规则说明</view>

    <view class="sub-title">常见胡法说明</view>
    <block wx:for="{{hufaList}}" wx:key="title" wx:for-item="item">
      <view class="item-card">
        <view class="item-title">{{item.title}}</view>
        <view class="item-detail">{{item.detail}}</view>
        <view class="item-options" wx:if="{{item.options}}">{{item.options}}</view>
      </view>
    </block>
    <view class="note">{{hufaNote}}</view>

    <view class="sub-title">规则说明</view>
    <block wx:for="{{ruleList}}" wx:key="title" wx:for-item="item">
      <view class="item-card">
        <view class="item-title">{{item.title}}</view>
        <view class="item-detail">{{item.detail}}</view>
        <view class="item-options" wx:if="{{item.options}}">{{item.options}}</view>
      </view>
    </block>
  </view>

  <view class="card section-card">
    <view class="section-name">翻倍计算方式</view>

    <view class="sub-title">计算说明</view>
    <block wx:for="{{calcSummary}}" wx:key="*this" wx:for-item="line" wx:for-index="idx">
      <view class="line-item">{{idx + 1}}. {{line}}</view>
    </block>

    <view class="sub-title">示例</view>
    <block wx:for="{{calcCases}}" wx:key="title" wx:for-item="item">
      <view class="item-card">
        <view class="item-title">{{item.title}}</view>
        <view class="item-detail">{{item.detail}}</view>
      </view>
    </block>
  </view>
</view>
