<view class="page">
  <view class="card head-card">
    <view class="section-title">{{title}}</view>
    <view class="sub">版本：{{version}}</view>
    <view class="intro">{{intro}}</view>
  </view>

  <view class="card section-card">
    <view class="section-name">基础说明</view>
    <block wx:for="{{basicNotes}}" wx:key="*this" wx:for-item="note" wx:for-index="idx">
      <view class="rule-item">{{idx + 1}}. {{note}}</view>
    </block>
  </view>

  <view class="card section-card">
    <view class="section-name">可配置规则项</view>
    <block wx:for="{{ruleItems}}" wx:key="id" wx:for-item="rule" wx:for-index="idx">
      <view class="config-item">
        <view class="config-title">{{idx + 1}}. {{rule.name}}</view>
        <view class="config-detail">{{rule.detail}}</view>
        <view class="config-options">选项：{{rule.optionsText}}</view>
      </view>
    </block>
  </view>
</view>
