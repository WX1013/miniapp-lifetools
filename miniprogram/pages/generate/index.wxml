<view class="page">
  <view class="card top-card">
    <view class="section-title">组局消息生成器</view>
    <view class="sub">按规则项选择后自动拼装组局文案，支持再次修改。</view>
  </view>

  <view class="card form-card">
    <view class="section-title small">组局信息</view>
    <view class="field">
      <text class="label">日期</text>
      <picker mode="date" value="{{form.gameDate}}" start="2020-01-01" end="2099-12-31" bindchange="onPickDate">
        <view class="picker">{{form.gameDate || '请选择日期'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">时间</text>
      <picker mode="time" value="{{form.gameTime}}" bindchange="onPickTime">
        <view class="picker">{{form.gameTime}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">地点</text>
      <input class="input" data-key="location" value="{{form.location}}" placeholder="如：滨江区某某茶室" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">局数</text>
      <input class="input" data-key="rounds" value="{{form.rounds}}" placeholder="如：8圈" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">费用方式</text>
      <picker mode="selector" range="{{payTypeOptions}}" value="{{form.payTypeIndex}}" bindchange="onPickPayType">
        <view class="picker">{{payTypeOptions[form.payTypeIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">联系方式</text>
      <input class="input" data-key="contact" value="{{form.contact}}" placeholder="微信号或手机号" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">备注</text>
      <textarea class="textarea" data-key="note" value="{{form.note}}" maxlength="200" bindinput="onInput" placeholder="如：禁烟，迟到发红包"></textarea>
    </view>
  </view>

  <view class="card form-card">
    <view class="section-title small">规则项选择</view>
    <block wx:for="{{ruleSelections}}" wx:key="ruleId" wx:for-item="rule">
      <view class="field">
        <text class="label">{{rule.ruleName}}</text>
        <picker mode="selector" range="{{rule.options}}" value="{{rule.selectedIndex}}" data-rule-id="{{rule.ruleId}}" bindchange="onPickRule">
          <view class="picker">{{rule.options[rule.selectedIndex]}}</view>
        </picker>
      </view>
    </block>

    <view class="btn-row">
      <button class="btn primary" bindtap="onGenerate">生成消息</button>
      <button class="btn" bindtap="onReset">重置</button>
    </view>
  </view>

  <view class="card output-card">
    <view class="section-title">生成结果</view>
    <view class="output">{{generatedText || '点击“生成消息”后展示文本内容'}}</view>
    <button class="btn primary copy-btn" bindtap="onCopy">复制消息</button>
  </view>
</view>
